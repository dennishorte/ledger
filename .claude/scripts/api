#!/usr/bin/env bash
# Query the local ledger API server (default :4180).
# Pretty-prints JSON via jq when available; falls back to raw.
#
# Usage:
#   api <path> [--raw] [--port N]
#   api _health
#   api docs
#   api docs/01-ui/02-dag
set -euo pipefail

path=""; raw=0; port="${LEDGER_PORT:-4180}"
while (( $# )); do
  case "$1" in
    --raw) raw=1; shift ;;
    --port) port="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) path="$1"; shift ;;
  esac
done

if [[ -z "$path" ]]; then
  echo "usage: api <path> [--raw] [--port N]" >&2
  exit 2
fi

url="http://127.0.0.1:${port}/api/${path#/}"
if (( raw )); then
  curl -sS --max-time 10 "$url"
else
  body=$(curl -sS --max-time 10 "$url")
  if command -v jq >/dev/null 2>&1 && printf '%s' "$body" | jq . >/dev/null 2>&1; then
    printf '%s' "$body" | jq .
  else
    printf '%s\n' "$body"
  fi
fi
