#!/usr/bin/env bash
# Curl wrapper restricted to the local ledger API server.
#
# Passes every argument through to curl unchanged EXCEPT the URL, which must
# be a relative path starting with /api/ — the wrapper prepends
# http://127.0.0.1:${LEDGER_PORT:-4180}. Absolute URLs (anything containing
# "://") are rejected, so the wrapper cannot be coerced into calling arbitrary
# hosts.
#
# All curl features pass through: -X, -H, -d, -N, --max-time, -o, -w, etc.
#
# Usage:
#   api-curl /api/<path>
#   api-curl [curl options] /api/<path> [more options]
#
# Examples:
#   api-curl /api/tasks
#   api-curl -X POST /api/tasks -H 'Content-Type: application/json' -d '{"type":"noop","title":"x"}'
#   api-curl -N --max-time 3 /api/tasks/<id>/stream
#   api-curl -H 'Last-Event-ID: 0' -N --max-time 3 /api/tasks/<id>/stream
#   api-curl -o /dev/null -w '%{http_code}\n' /api/tasks/missing
set -euo pipefail

if [[ $# -eq 0 ]] || [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
  exit 0
fi

port="${LEDGER_PORT:-4180}"
host="http://127.0.0.1:${port}"

rewritten=()
path_count=0
for arg in "$@"; do
  if [[ "$arg" == *"://"* ]]; then
    echo "api-curl: absolute URLs are not allowed; use /api/<path>" >&2
    exit 2
  elif [[ "$arg" =~ ^/api(/|$) ]]; then
    rewritten+=("${host}${arg}")
    path_count=$((path_count + 1))
  else
    rewritten+=("$arg")
  fi
done

if [[ $path_count -eq 0 ]]; then
  echo "api-curl: missing /api/<path> argument" >&2
  exit 2
fi

exec curl "${rewritten[@]}"
