{
  "name": "@ledger/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ledger": "./dist/bin/ledger.js"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../.env src/bin/ledger.ts --no-open",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "build": "tsc -b && cp src/runner/migrations/*.sql dist/runner/migrations/"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@ledger/parser": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "execa": "^9.6.1",
    "hono": "^4.6.0",
    "open": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.7"
  }
}
